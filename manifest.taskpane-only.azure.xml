<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xsi:type="MailApp">
  <Id>7c8d2d58-857b-4b91-98c4-0dd404f91f48</Id>
  <Version>0.1.0.1</Version>
  <ProviderName>Recipient Guard</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Recipient Guard Task Pane POC" />
  <Description DefaultValue="Recipient Guard task pane proof of concept for New Outlook." />
  <IconUrl DefaultValue="https://rgoutlookpoc0618.z33.web.core.windows.net/assets/icon.jpg" />
  <HighResolutionIconUrl DefaultValue="https://rgoutlookpoc0618.z33.web.core.windows.net/assets/icon.jpg" />
  <SupportUrl DefaultValue="https://rgoutlookpoc0618.z33.web.core.windows.net/src/taskpane.html" />
  <AppDomains>
    <AppDomain>https://rgoutlookpoc0618.z33.web.core.windows.net</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.8" />
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://rgoutlookpoc0618.z33.web.core.windows.net/src/taskpane.html?v=20260624-1" />
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.8">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="RecipientGuard.Group">
                <Label resid="Group.Label" />
                <Control xsi:type="Button" id="RecipientGuard.OpenPane">
                  <Label resid="OpenPane.Label" />
                  <Supertip>
                    <Title resid="OpenPane.Label" />
                    <Description resid="OpenPane.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16" />
                    <bt:Image size="32" resid="Icon.32" />
                    <bt:Image size="80" resid="Icon.80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://rgoutlookpoc0618.z33.web.core.windows.net/assets/icon.jpg" />
        <bt:Image id="Icon.32" DefaultValue="https://rgoutlookpoc0618.z33.web.core.windows.net/assets/icon.jpg" />
        <bt:Image id="Icon.80" DefaultValue="https://rgoutlookpoc0618.z33.web.core.windows.net/assets/icon.jpg" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://rgoutlookpoc0618.z33.web.core.windows.net/src/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://rgoutlookpoc0618.z33.web.core.windows.net/src/taskpane.html?v=20260624-1" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="Group.Label" DefaultValue="Recipient Guard" />
        <bt:String id="OpenPane.Label" DefaultValue="Recipient Guard" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="OpenPane.Tooltip" DefaultValue="Open Recipient Guard recipient checks." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
